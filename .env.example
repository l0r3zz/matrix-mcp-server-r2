# Matrix MCP Server R2 Configuration
# Copy to .env and customize for your environment.

# ── Core Matrix Settings (required) ──────────────────────────────────
MATRIX_HOMESERVER_URL=https://localhost:8008/
MATRIX_USER_ID=@bot:example.com
MATRIX_ACCESS_TOKEN=syt_your_access_token_here
MATRIX_DOMAIN=example.com

# ── MCP Server ───────────────────────────────────────────────────────
PORT=3000
# MCP_PORT=3000  (alias for PORT)

# ── CORS ─────────────────────────────────────────────────────────────
# Leave empty for development (allows all origins).
# For production, comma-separated allowed origins:
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── HTTPS ────────────────────────────────────────────────────────────
ENABLE_HTTPS=false
# SSL_KEY_PATH=/path/to/key.pem
# SSL_CERT_PATH=/path/to/cert.pem

# ── OAuth / Token Exchange (optional) ────────────────────────────────
ENABLE_OAUTH=false
ENABLE_TOKEN_EXCHANGE=false
# IDP_ISSUER_URL=https://keycloak.example.com/realms/myrealm
# IDP_AUTHORIZATION_URL=...
# IDP_TOKEN_URL=...
# IDP_REGISTRATION_URL=...
# IDP_REVOCATION_URL=...
# OAUTH_CALLBACK_URL=http://localhost:3000/callback
# MCP_SERVER_URL=http://localhost:3000/mcp
# MATRIX_CLIENT_ID=matrix-mcp
# MATRIX_CLIENT_SECRET=secret

# ── E2EE (future, requires --features e2ee) ─────────────────────────
E2EE_ENABLED=false
# CRYPTO_STORE_PATH=/data/crypto-store

# ── Debug ────────────────────────────────────────────────────────────
# DEBUG=true
# RUST_LOG=info,matrix_mcp_server_r2=debug
